# ─── WindTranslator 环境配置 ─────────────────────────────────
# 复制为 .env 并填入实际值: cp .env.example .env

# ─── 数据库 ──────────────────────────────────────────────────
# 默认 SQLite，生产可换 PostgreSQL:
#   WT_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/windtranslator
WT_DATABASE_URL=sqlite+aiosqlite:///./data/wind_translator.db

# ─── Redis（Celery 任务队列 + WebSocket 消息推送）─────────────
# Docker 部署时由 compose 覆盖为 redis://redis:6379/0
WT_REDIS_URL=redis://localhost:6379/0

# ─── 文件存储 ────────────────────────────────────────────────
WT_UPLOAD_DIR=uploads
WT_OUTPUT_DIR=outputs

# ─── 安全 ────────────────────────────────────────────────────
# Fernet 对称加密密钥，用于存储 API key
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WT_ENCRYPTION_KEY=

# ─── 翻译引擎 ────────────────────────────────────────────────
# 每批次字符上限（影响 LLM 单次请求大小）
WT_BATCH_CHAR_LIMIT=2000
# 单次翻译最大重试次数
WT_MAX_RETRIES=3

# ─── 部署 ────────────────────────────────────────────────────
# 前端对外端口（仅 docker compose 使用）
WT_PORT=80

# CORS 允许来源（逗号分隔，容器部署通常无需修改）
WT_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
